{
  "name": "gma2-language",
  "displayName": "grandMA2 Language Support",
  "description": "Language support for grandMA2 lighting console command scripts -- syntax highlighting and hover documentation for cue programming, fixture control, and show file authoring",
  "version": "0.0.1",
  "publisher": "chienchuanw",
  "license": "MIT",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.75.0"
  },
  "activationEvents": [
    "onLanguage:gma2"
  ],
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "grandMA2",
    "gma2",
    "MA Lighting",
    "lighting console",
    "stage lighting",
    "DMX",
    "syntax highlighting",
    "cue programming",
    "show control",
    "live production"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chienchuanw/gma2-vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/chienchuanw/gma2-vscode-extension/issues"
  },
  "homepage": "https://github.com/chienchuanw/gma2-vscode-extension#readme",
  "contributes": {
    "languages": [
      {
        "id": "gma2",
        "aliases": [
          "grandMA2",
          "gma2",
          "GMA2"
        ],
        "extensions": [
          ".gma2"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gma2",
        "scopeName": "source.gma2",
        "path": "./syntaxes/gma2.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "compile": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "package": "pnpm run compile && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3"
  }
}
